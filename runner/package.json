{
  "name": "@zev2/agent-runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dry-run": "pnpm --filter @zev2/shared build && tsx src/index.ts",
    "dry-run:no-build": "tsx src/index.ts",
    "build": "pnpm --filter @zev2/shared build && tsc -p tsconfig.json",
    "type-check": "pnpm --filter @zev2/shared build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@zev2/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
